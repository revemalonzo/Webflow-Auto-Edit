# Webflow API tokens — try in order (1 → 4) until the target site is found
# Get these from Webflow Dashboard → Account Settings → API Access
WEBFLOW_API_TOKEN_1=
WEBFLOW_API_TOKEN_2=
WEBFLOW_API_TOKEN_3=
WEBFLOW_API_TOKEN_4=

# BugHerd API key — used to fetch missing selector/HTML data from tickets
# Get this from BugHerd → Settings → API
BUGHERD_API_KEY=

# Linear API key — used to read and update tickets
# Get this from Linear → Settings → API → Personal API keys
LINEAR_API_KEY=

# OpenAI API key — enables AI fallback resolution (field slugs, static elements,
# H1 text, template pages) when deterministic matching fails. Optional but
# recommended; without it, AI fallback steps are silently skipped.
OPENAI_API_KEY=

# Optional: manually target a specific batch (parent ticket or solo ticket) instead
# of polling. Text updater only. e.g. https://linear.app/pushpress/issue/BUGHERD-12345/...
BATCH_URL=

# Optional: same as BATCH_URL but for the image updater (src/image-index.js) --
# kept separate so the two pipelines can be pointed at different tickets independently.
IMAGE_BATCH_URL=

# Cloudinary cloud name — used to construct unsigned remote-fetch transform URLs
# for the image updater. No API key needed; this account allows unsigned fetch.
CLOUDINARY_CLOUD_NAME=

# Optional: set to "true" to run without actually writing to Webflow/Linear (for testing)
DRY_RUN=false
