# Webflow API tokens — try in order (1 → 4) until the target site is found
# Get these from Webflow Dashboard → Account Settings → API Access
WEBFLOW_API_TOKEN_1=
WEBFLOW_API_TOKEN_2=
WEBFLOW_API_TOKEN_3=
WEBFLOW_API_TOKEN_4=

# BugHerd API key — used to fetch missing selector/HTML data from tickets
# Get this from BugHerd → Settings → API
BUGHERD_API_KEY=

# Linear API key — used to read and update tickets
# Get this from Linear → Settings → API → Personal API keys
LINEAR_API_KEY=

# Optional: set to "true" to run without actually writing to Webflow/Linear (for testing)
DRY_RUN=false
